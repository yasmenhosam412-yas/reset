# Copy this file to:  supabase/.env.secrets  (that path is gitignored — NEVER put real keys in *.example)
#
# Deploy Edge Function (no global CLI):
#   .\scripts\deploy_process_push_queue.ps1
#
# Push secrets to Supabase (after installing CLI or using downloaded .tools CLI):
#   supabase secrets set --env-file supabase/.env.secrets
#
# FIREBASE_SERVICE_ACCOUNT_JSON:
#   - Paste the ENTIRE service account JSON from Firebase as ONE LINE (no real line breaks).
#   - The downloaded file has "private_key": "-----BEGIN...\\n...\\n-----END...\\n" — keep those \n escapes; do not split across lines in this file.
#   - Easiest: minify with a JSON minifier locally, then paste one line after the = below.
#
# PUSH_PROCESS_SECRET:
#   - Long random string; store as Edge secret and use the SAME value on the webhook as EITHER:
#       Authorization: Bearer <that exact string>   (recommended — always forwarded)
#       or apikey: <that exact string>
#       or header x-push-process-secret: <that exact string>
#   - Do not paste real secrets into chat or commit them to git.

FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id","private_key_id":"YOUR_KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\\nREPLACE_WITH_YOUR_KEY_FROM_FIREBASE_CONSOLE\\n-----END PRIVATE KEY-----\\n","client_email":"firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com","client_id":"000000000000000000000","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxxx%40your-project-id.iam.gserviceaccount.com","universe_domain":"googleapis.com"}
PUSH_PROCESS_SECRET=replace-with-a-long-random-string-for-webhook-auth

# After saving secrets in Dashboard or via CLI, redeploy:
#   .\scripts\deploy_process_push_queue.ps1
